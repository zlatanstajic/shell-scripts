# NOTE: dry-run (-n/--dry-run) and assume-yes (-y/--yes) are CLI flags, not .env
# keys; setting DRY_RUN/ASSUME_YES here has no effect (scripts reset them after
# sourcing this file).

################################################################################
# dev-setup.sh
################################################################################

BRANCH_PREFIX="issues"
REQUEST_PREFIX="refs:"
# NOTE: Issue base path will vary based on your project name folder (if you use GitHub)
# Example: https://github.com/your-username
ISSUE_BASE_PATH=""
# GitLab numeric user id to pre-assign on the merge request (e.g. 116). Leave empty to omit the assignee.
GITLAB_ASSIGNEE_ID=""

################################################################################
# src/scripts/backup.sh
################################################################################

# Backup location
BACKUP_LOCATION="/home/your-username/Documents/backup/automated"

# System
SYSTEM_DESTINATION_FOLDER_NAME="system"
SYSTEM_SOURCE_PATHS="/home/your-username/.bashrc,/home/your-username/.gitconfig,/etc/hosts,/etc/apache2/sites-available/000-default.conf"

# VS Code
VSCODE_DESTINATION_FOLDER_NAME="vscode"
VSCODE_SOURCE_PATHS="/home/your-username/.config/Code/User/settings.json,/home/your-username/.config/Code/User/snippets/global-snippets.code-snippets"

# Projects
PROJECTS_DESTINATION_FOLDER_NAME="projects"
# Example: "/var/www/project-one,/var/www/project-two"
PROJECTS_SOURCE_PATHS=""

# Password used to AES-256-CBC encrypt project .env files during backup so they
# can be recovered later (defaults to "pa55" if not set). Set a STRONG password
# here; encryption is only as good as this value.
ENV_FILES_PASSWORD="pa55"

# Deployments
DEPLOYMENTS_DESTINATION_FOLDER_NAME="deployments"
# Example: "/var/www/project-one/deploy,/var/www/project-two/deploy"
DEPLOYMENT_SOURCE_PATHS=""

################################################################################
# src/scripts/hash-filenames.sh
################################################################################

# Comma-separated list of file extensions to process (case-insensitive; the
# leading dot is optional). Only files with these extensions are renamed/moved.
HASH_FILENAMES_FILE_EXTENSIONS="jpg,jpeg,png,gif,webp"

################################################################################
# src/scripts/git-copy.sh
################################################################################

# Parent directory under which a folder named after the current repo
# (<repo-basename>) is created to receive the copied files. The -t flag
# overrides this verbatim (used as the full target path, repo basename NOT
# appended).
GIT_COPY_TARGET_DIRECTORY_PATH=""

################################################################################
# src/scripts/restore-vscode-folder.sh
################################################################################

# Reuses BACKUP_LOCATION and PROJECTS_DESTINATION_FOLDER_NAME (defined above
# under backup.sh). Restores <BACKUP_LOCATION>/<PROJECTS_DESTINATION_FOLDER_NAME>/
# <current-dir-basename>/.vscode into the current directory.

################################################################################
# src/scripts/splice-images.sh
################################################################################

# Comma-separated list of valid image extensions (case-insensitive; the leading
# dot is optional). Used to pick random images from the current directory and to
# filter images passed via -i.
SPLICE_IMAGES_FILE_EXTENSIONS="jpg,jpeg,png,gif,webp"

################################################################################
# src/scripts/splice-videos.sh
################################################################################

# Comma-separated list of valid video extensions (case-insensitive; the leading
# dot is optional). Used to validate the input video passed via -i.
SPLICE_VIDEOS_FILE_EXTENSIONS="mp4,mov,mkv,webm"

################################################################################
# src/scripts/tampermonkey-install.sh
################################################################################

# Base URL(s) under which userscripts live as <base>/<domain>/<script>.user.js.
# Accepts a single URL or a comma-separated list. When multiple URLs are given
# the script probes each with curl --head (follows redirects, 5 s timeout, soft
# dependency) and opens the first that returns HTTP 2xx; falls back to the first
# URL when none return 2xx or curl is absent. github.com /raw/ URLs answer with
# a 302 to raw.githubusercontent.com, so redirects must be followed for the
# probe to be accurate. For PRIVATE repos the probe must authenticate or every
# candidate looks like a 404: it sends a GitHub token (first of $GH_TOKEN,
# $GITHUB_TOKEN, then `gh auth token`) but only to github.com candidates. With
# no token, private candidates probe as 404 and the first URL is used. The
# -r/--repo flag overrides this value verbatim (no probing).
TAMPERMONKEY_REPO_BASE_URLS="https://github.com/[username]/[repository]/raw/refs/heads/master/[tampermonkey-scripts]/"

################################################################################
# src/scripts/rain-alert.sh
################################################################################

# Cities to check, as a whitespace- or comma-separated list of "name:lat:lon"
# entries (a scalar string, not a bash array). lat/lon must be numeric; malformed
# entries are warned about and skipped.
RAIN_ALERT_CITIES="Belgrade:44.7866:20.4489 Berlin:52.52:13.405"

# How many hours ahead to scan the forecast for rain (default 24).
RAIN_ALERT_LOOKAHEAD_HOURS="24"

# Minimum next-hour precipitation in mm to count as rain even when the symbol
# code is not rain/sleet/thunder (default 0 = any measurable amount counts).
RAIN_ALERT_PRECIP_THRESHOLD_MM="0"

# Recipient address for the alert email (REQUIRED — the script ends with an
# error when empty).
RAIN_ALERT_RECIPIENT=""

# msmtp account name to send through (passed as --account=...; leave empty to
# use your msmtp default account).
RAIN_ALERT_MSMTP_ACCOUNT=""

# User-Agent sent to api.met.no. MET Norway's terms require a descriptive agent
# that identifies your application and a contact (site name + email).
RAIN_ALERT_USER_AGENT="shell-scripts rain-alert (contact@zlatanstajic.com)"

# Seconds to sleep between per-city API requests (met.no TOS; default 1).
RAIN_ALERT_THROTTLE_SECONDS="1"

# Where the last-sent alert signature is cached so an hourly cron does not
# re-send an unchanged forecast. The parent directory is created as needed.
RAIN_ALERT_CACHE_FILE="$HOME/.cache/rain-alert/last-alert.txt"

# A real send needs msmtp (configure ~/.msmtprc). Without it you can pipe the
# composed message to curl over SMTP instead, e.g.:
#   curl --ssl-reqd --mail-from you@example.com --mail-rcpt rcpt@example.com \
#     --upload-file msg.txt --user you@example.com:pass smtps://smtp.host:465
</content>
