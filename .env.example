# NOTE: dry-run (-n/--dry-run) and assume-yes (-y/--yes) are CLI flags, not .env
# keys; setting DRY_RUN/ASSUME_YES here has no effect (scripts reset them after
# sourcing this file).

################################################################################
# dev-setup.sh
################################################################################

BRANCH_PREFIX="issues"
REQUEST_PREFIX="refs:"
# NOTE: Issue base path will vary based on your project name folder (if you use GitHub)
# Example: https://github.com/your-username
ISSUE_BASE_PATH=""
# GitLab numeric user id to pre-assign on the merge request (e.g. 116). Leave empty to omit the assignee.
GITLAB_ASSIGNEE_ID=""

################################################################################
# src/scripts/backup.sh
################################################################################

# Backup location
BACKUP_LOCATION="/home/your-username/Documents/backup/automated"

# System
SYSTEM_DESTINATION_FOLDER_NAME="system"
SYSTEM_SOURCE_PATHS="/home/your-username/.bashrc,/home/your-username/.gitconfig,/etc/hosts,/etc/apache2/sites-available/000-default.conf"

# VS Code
VSCODE_DESTINATION_FOLDER_NAME="vscode"
VSCODE_SOURCE_PATHS="/home/your-username/.config/Code/User/settings.json,/home/your-username/.config/Code/User/snippets/global-snippets.code-snippets"

# Projects
PROJECTS_DESTINATION_FOLDER_NAME="projects"
# Example: "/var/www/project-one,/var/www/project-two"
PROJECTS_SOURCE_PATHS=""

# Key used to HMAC-hash .env files for change detection during backup (defaults to "pa55" if not set)
ENV_FILES_ZIP_PASSWORD="pa55"

# Deployments
DEPLOYMENTS_DESTINATION_FOLDER_NAME="deployments"
# Example: "/var/www/project-one/deploy,/var/www/project-two/deploy"
DEPLOYMENT_SOURCE_PATHS=""

################################################################################
# src/scripts/hash-filenames.sh
################################################################################

# Comma-separated list of file extensions to process (case-insensitive; the
# leading dot is optional). Only files with these extensions are renamed/moved.
HASH_FILENAMES_FILE_EXTENSIONS="jpg,jpeg,png,gif,webp"

################################################################################
# src/scripts/git-copy.sh
################################################################################

# Parent directory under which a folder named after the current repo
# (<repo-basename>) is created to receive the copied files. The -t flag
# overrides this verbatim (used as the full target path, repo basename NOT
# appended).
GIT_COPY_TARGET_DIRECTORY_PATH=""

################################################################################
# src/scripts/restore-vscode-folder.sh
################################################################################

# Reuses BACKUP_LOCATION and PROJECTS_DESTINATION_FOLDER_NAME (defined above
# under backup.sh). Restores <BACKUP_LOCATION>/<PROJECTS_DESTINATION_FOLDER_NAME>/
# <current-dir-basename>/.vscode into the current directory.

################################################################################
# src/scripts/splice-images.sh
################################################################################

# Comma-separated list of valid image extensions (case-insensitive; the leading
# dot is optional). Used to pick random images from the current directory and to
# filter images passed via -i.
SPLICE_IMAGES_FILE_EXTENSIONS="jpg,jpeg,png,gif,webp"

################################################################################
# src/scripts/splice-videos.sh
################################################################################

# Comma-separated list of valid video extensions (case-insensitive; the leading
# dot is optional). Used to validate the input video passed via -i.
SPLICE_VIDEOS_FILE_EXTENSIONS="mp4,mov,mkv,webm"
</content>
